{
  "name": "alexa-hermes-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Alexa custom skill bridge that accepts voice requests and runs them asynchronously on Hermes, announcing results via Home Assistant",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ask-sdk-core": "^2.14.0",
    "ask-sdk-express-adapter": "^2.14.0",
    "better-sqlite3": "^12.2.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "pino": "^9.5.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
